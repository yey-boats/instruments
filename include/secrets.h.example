#pragma once

// Copy this file to include/secrets.h (which is gitignored) and fill in.
// If secrets.h is missing or values are empty, the device boots in AP mode
// at SSID "espdisp-setup" (no password) and you can set creds over Serial
// with:   wifi <ssid> <pass>

#define WIFI_SSID  ""
#define WIFI_PASS  ""

// mDNS / OTA hostname - the board will be reachable at <OTA_HOSTNAME>.local
#define OTA_HOSTNAME  "espdisp"

// Optional OTA password (empty = no auth). Set for production.
#define OTA_PASSWORD  ""

// UDP log broadcast port. nc -u -l 9999 to watch logs on LAN.
#define UDP_LOG_PORT 9999
