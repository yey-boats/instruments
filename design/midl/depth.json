{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "depth",
      "title": "Depth",
      "_note": "screen_depth = big DEPTH hero (below keel, m, k/M scaled, font_xl 64) + WATER TEMP + SOG + TWA + a depth-history sparkline (trend). The DEPTH hero carries a shallow-water alarm via style.zones (lt thresholds -> warn/accent). square-480 hero-split has 3 slots: hero=DEPTH, column=[WATER TEMP, depth-history trend] (the signature sparkline). Landscape variants reclaim space to surface SOG and TWA alongside water temp and the trend.",
      "elements": {
        "depth": {
          "type": "single-value",
          "name": "DEPTH",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.depth.belowKeel"
            }
          },
          "format": {
            "unit": "m",
            "decimals": 1
          },
          "style": {
            "title": "BELOW KEEL",
            "size": 64,
            "zones": [
              {
                "lt": 1.5,
                "color": "warn"
              },
              {
                "lt": 3,
                "color": "accent"
              }
            ]
          }
        },
        "watertemp": {
          "type": "single-value",
          "name": "WATER",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.water.temperature"
            }
          },
          "format": {
            "unit": "degC",
            "decimals": 1
          },
          "style": {
            "title": "WATER",
            "size": 20
          }
        },
        "sog": {
          "type": "single-value",
          "name": "SOG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.speedOverGround"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "SOG",
            "size": 20
          }
        },
        "twa": {
          "type": "single-value",
          "name": "TWA",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.wind.angleTrueWater"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "TWA",
            "size": 20
          }
        },
        "depthtrend": {
          "type": "trend",
          "name": "DEPTH HISTORY",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.depth.belowKeel"
            }
          },
          "format": {
            "unit": "m",
            "decimals": 1
          },
          "style": {
            "title": "DEPTH HISTORY",
            "size": 14
          }
        }
      },
      "layout": {
        "preset": "hero-split",
        "slots": [
          "depth",
          "watertemp",
          "depthtrend"
        ]
      },
      "variants": [
        {
          "class": "landscape-800x480",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "depth"
              },
              {
                "rows": 4,
                "cols": 1,
                "cells": [
                  {
                    "element": "watertemp"
                  },
                  {
                    "element": "sog"
                  },
                  {
                    "element": "twa"
                  },
                  {
                    "element": "depthtrend"
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "landscape-1024x600",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "depth"
              },
              {
                "rows": 4,
                "cols": 1,
                "cells": [
                  {
                    "element": "watertemp"
                  },
                  {
                    "element": "sog"
                  },
                  {
                    "element": "twa"
                  },
                  {
                    "element": "depthtrend"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
