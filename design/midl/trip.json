{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "trip",
      "title": "Trip",
      "_note": "screen_trip is a locally-integrated odometer: hero DISTANCE (nm), TIME UNDERWAY, AVG SPEED, MAX SPEED, plus a live SOG NOW strip. DISTANCE, underway time, avg and max SOG are device-local (kind:local) - the firmware persists them in NVS and has no SignalK path. Only live SOG is a SignalK path (navigation.speedOverGround). square-480 hero-split has 3 slots: hero=DISTANCE, column=[underway time, live SOG]. Landscape variants reclaim space to surface AVG and MAX speed alongside underway time and live SOG.",
      "elements": {
        "distance": {
          "type": "single-value",
          "name": "DISTANCE",
          "bindings": {
            "value": {
              "kind": "local",
              "id": "trip.distance"
            }
          },
          "format": {
            "unit": "nm",
            "decimals": 2
          },
          "style": {
            "title": "DISTANCE",
            "size": 64
          }
        },
        "time": {
          "type": "single-value",
          "name": "TIME",
          "bindings": {
            "value": {
              "kind": "local",
              "id": "trip.underway"
            }
          },
          "format": {
            "unit": "h",
            "decimals": 1
          },
          "style": {
            "title": "UNDERWAY",
            "size": 20
          }
        },
        "sognow": {
          "type": "single-value",
          "name": "SOG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.speedOverGround"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "SOG NOW",
            "size": 28
          }
        },
        "avg": {
          "type": "single-value",
          "name": "AVG SOG",
          "bindings": {
            "value": {
              "kind": "local",
              "id": "trip.avgSpeed"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "AVG SPEED",
            "size": 20
          }
        },
        "max": {
          "type": "single-value",
          "name": "MAX SOG",
          "bindings": {
            "value": {
              "kind": "local",
              "id": "trip.maxSpeed"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "MAX SPEED",
            "size": 20
          }
        }
      },
      "layout": {
        "preset": "hero-split",
        "slots": [
          "distance",
          "time",
          "sognow"
        ]
      },
      "variants": [
        {
          "class": "landscape-800x480",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "distance"
              },
              {
                "rows": 4,
                "cols": 1,
                "cells": [
                  {
                    "element": "time"
                  },
                  {
                    "element": "avg"
                  },
                  {
                    "element": "max"
                  },
                  {
                    "element": "sognow"
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "landscape-1024x600",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "distance"
              },
              {
                "rows": 4,
                "cols": 1,
                "cells": [
                  {
                    "element": "time"
                  },
                  {
                    "element": "avg"
                  },
                  {
                    "element": "max"
                  },
                  {
                    "element": "sognow"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
