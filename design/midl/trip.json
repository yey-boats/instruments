{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "trip",
      "title": "Trip",
      "_note": "screen_trip is a locally-integrated odometer: DISTANCE, underway time, avg/max SOG, live SOG. Only live SOG is a SignalK path (navigation.speedOverGround). DISTANCE and underway time are device-local (kind:local) - the firmware persists them in NVS and has no SignalK path. The config schema permits source kind:local, but the square-480 capability manifest advertises sources:[signalk] only, so these two tiles fail the capability (caps) layer by design - see validation report. Modeled hero-split: hero=DISTANCE, column=[underway time, live SOG]; avg/max SOG dropped.",
      "elements": {
        "distance": {
          "type": "single-value",
          "name": "DISTANCE",
          "bindings": {
            "value": {
              "kind": "local",
              "id": "trip.distance"
            }
          },
          "format": {
            "unit": "nm",
            "decimals": 2
          },
          "style": {
            "title": "DISTANCE",
            "size": 48
          }
        },
        "time": {
          "type": "single-value",
          "name": "TIME",
          "bindings": {
            "value": {
              "kind": "local",
              "id": "trip.underway"
            }
          },
          "format": {
            "unit": "h",
            "decimals": 1
          },
          "style": {
            "title": "UNDERWAY",
            "size": 20
          }
        },
        "sognow": {
          "type": "single-value",
          "name": "SOG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.speedOverGround"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "SOG",
            "size": 28
          }
        },
        "avg": {
          "type": "single-value",
          "name": "AVG SOG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.speedOverGround"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "AVG SOG",
            "size": 28
          }
        }
      },
      "layout": {
        "preset": "hero-split",
        "slots": [
          "distance",
          "time",
          "sognow"
        ]
      },
      "variants": [
        {
          "class": "landscape-800x480",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "distance"
              },
              {
                "rows": 3,
                "cols": 1,
                "cells": [
                  {
                    "element": "time"
                  },
                  {
                    "element": "sognow"
                  },
                  {
                    "element": "avg"
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "landscape-1024x600",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "distance"
              },
              {
                "rows": 3,
                "cols": 1,
                "cells": [
                  {
                    "element": "time"
                  },
                  {
                    "element": "sognow"
                  },
                  {
                    "element": "avg"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
