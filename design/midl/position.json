{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "position",
      "title": "Position",
      "_note": "Built on the design text-position widget: navigation.position rendered as a two-line lat/lon text hero, flanked by COG/SOG/HDG and a heading compass. The renderer formats the SignalK position object {latitude,longitude} into deg+decimal-minutes per hemisphere.",
      "elements": {
        "pos": {
          "type": "text",
          "name": "POSITION",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.position"
            }
          },
          "style": {
            "title": "POSITION",
            "size": 24
          }
        },
        "cog": {
          "type": "single-value",
          "name": "COG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseOverGroundTrue"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "COG",
            "size": 28
          }
        },
        "sog": {
          "type": "single-value",
          "name": "SOG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.speedOverGround"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "SOG",
            "size": 28
          }
        },
        "hdg": {
          "type": "single-value",
          "name": "HDG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.headingTrue"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "HDG",
            "size": 28
          }
        },
        "compass": {
          "type": "compass",
          "name": "HDG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.headingTrue"
            }
          },
          "style": {
            "title": "HDG",
            "size": 48
          },
          "markers": [
            {
              "id": "COG",
              "glyph": "chevron_out",
              "color": "accent",
              "dir": {
                "kind": "signalk",
                "path": "navigation.courseOverGroundTrue"
              }
            }
          ]
        },
        "dtw": {
          "type": "single-value",
          "name": "DTW",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseRhumbline.nextPoint.distance"
            }
          },
          "format": {
            "unit": "nm",
            "decimals": 2
          },
          "style": {
            "title": "DTW",
            "size": 28
          }
        },
        "dtw2": {
          "type": "single-value",
          "name": "DTW",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseRhumbline.nextPoint.distance"
            }
          },
          "format": {
            "unit": "nm",
            "decimals": 2
          },
          "style": {
            "title": "DTW",
            "size": 28
          }
        }
      },
      "layout": {
        "rows": 2,
        "cols": 2,
        "cells": [
          {
            "element": "pos"
          },
          {
            "element": "cog"
          },
          {
            "element": "sog"
          },
          {
            "element": "hdg"
          }
        ]
      },
      "variants": [
        {
          "class": "landscape-800x480",
          "layout": {
            "flow": "row",
            "weights": [
              2,
              3
            ],
            "children": [
              {
                "element": "pos"
              },
              {
                "rows": 2,
                "cols": 2,
                "cells": [
                  {
                    "element": "compass"
                  },
                  {
                    "element": "cog"
                  },
                  {
                    "element": "sog"
                  },
                  {
                    "element": "hdg"
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "landscape-1024x600",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              3
            ],
            "children": [
              {
                "element": "compass"
              },
              {
                "rows": 3,
                "cols": 2,
                "cells": [
                  {
                    "element": "pos"
                  },
                  {
                    "element": "cog"
                  },
                  {
                    "element": "sog"
                  },
                  {
                    "element": "hdg"
                  },
                  {
                    "element": "dtw"
                  },
                  {
                    "element": "dtw2"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
