{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "wind_steer",
      "title": "Wind Steer",
      "_note": "screen_wind_steer overlays a heading compass with HDG/COG/CTS/TWD markers, four wind readouts (AWS/AWA/TWS/TWA) and a tack/gybe + course-adjust button row. square-480 maxTiles=4: modeled as compass + a wind readout + tack + gybe buttons. AWA/TWS/TWA and the +/-course-trim buttons are dropped from the tiling. Firmware autopilot writes go to steering/autopilot/target/headingTrue; tack/gybe are exposed as command actions (manifest actionKinds=[nav,command]; put is not a device action kind).",
      "elements": {
        "compass": {
          "type": "compass",
          "name": "HDG",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.headingTrue"
            }
          },
          "style": {
            "title": "HDG",
            "size": 48,
            "shape": "band"
          },
          "markers": [
            {
              "id": "HDG",
              "glyph": "triangle",
              "color": "fg",
              "dir": {
                "kind": "signalk",
                "path": "navigation.headingTrue"
              }
            },
            {
              "id": "COG",
              "glyph": "chevron_out",
              "color": "accent",
              "dir": {
                "kind": "signalk",
                "path": "navigation.courseOverGroundTrue"
              }
            },
            {
              "id": "CTS",
              "glyph": "diamond",
              "color": "good",
              "dir": {
                "kind": "signalk",
                "path": "navigation.courseRhumbline.bearingTrackTrue"
              }
            },
            {
              "id": "TWD",
              "glyph": "bar",
              "color": "warn",
              "dir": {
                "kind": "signalk",
                "path": "environment.wind.directionTrue"
              }
            }
          ]
        },
        "aws": {
          "type": "single-value",
          "name": "AWS",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.wind.speedApparent"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "AWS",
            "size": 28
          }
        },
        "tack": {
          "type": "button",
          "name": "TACK",
          "style": {
            "title": "TACK",
            "size": 20
          },
          "action": {
            "kind": "command",
            "target": "ap-tack"
          }
        },
        "gybe": {
          "type": "button",
          "name": "GYBE",
          "style": {
            "title": "GYBE",
            "size": 20
          },
          "action": {
            "kind": "command",
            "target": "ap-gybe"
          }
        },
        "awa": {
          "type": "single-value",
          "name": "AWA",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.wind.angleApparent"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "AWA",
            "size": 28
          }
        },
        "tws": {
          "type": "single-value",
          "name": "TWS",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.wind.speedTrue"
            }
          },
          "format": {
            "unit": "kn",
            "decimals": 1
          },
          "style": {
            "title": "TWS",
            "size": 28
          }
        },
        "twa": {
          "type": "single-value",
          "name": "TWA",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "environment.wind.angleTrueWater"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "TWA",
            "size": 28
          }
        }
      },
      "layout": {
        "flow": "col",
        "weights": [
          3,
          1
        ],
        "children": [
          {
            "element": "compass"
          },
          {
            "flow": "row",
            "children": [
              {
                "element": "aws"
              },
              {
                "element": "tack"
              },
              {
                "element": "gybe"
              }
            ]
          }
        ]
      },
      "variants": [
        {
          "class": "landscape-800x480",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              2
            ],
            "children": [
              {
                "element": "compass"
              },
              {
                "rows": 2,
                "cols": 2,
                "cells": [
                  {
                    "element": "aws"
                  },
                  {
                    "element": "awa"
                  },
                  {
                    "element": "tack"
                  },
                  {
                    "element": "gybe"
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "landscape-1024x600",
          "layout": {
            "flow": "row",
            "weights": [
              3,
              3
            ],
            "children": [
              {
                "element": "compass"
              },
              {
                "rows": 3,
                "cols": 2,
                "cells": [
                  {
                    "element": "aws"
                  },
                  {
                    "element": "awa"
                  },
                  {
                    "element": "tws"
                  },
                  {
                    "element": "twa"
                  },
                  {
                    "element": "tack"
                  },
                  {
                    "element": "gybe"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
