# Local-only test secrets — copy to `.env.test.local` (gitignored) and fill in.
# `.env.test` auto-sources this file if it exists.

# WPA2-PSK for the `yey-net` AP on compulab.  Used by:
#   - signalk/scripts/lab-ap-setup.sh (passed as $1 by the operator when
#     running the script directly, OR exported into the env if your sudoers
#     preserves env)
#   - tools/provision_device.py (read from env at startup)
# Pick something memorable; rotate by editing /etc/espdisp-lab/hostapd.conf
# on compulab + `pkill -f hostapd.conf && sudo bash /usr/local/sbin/yeydisp-lab-ap-setup.sh`.
export YEY_NET_PSK="changeme"
