+def _cur_set_deg(utc_now: datetime) -> float:
+    """Modeled tidal-current set (deg true): swings slowly around the Adriatic
+    NW->SE drift."""
+    p = utc_now.timestamp()
+    return (150.0 + 30.0 * math.sin(p / 600.0)) % 360.0
+
+
+def _cur_drift_kts(utc_now: datetime) -> float:
+    """Modeled tidal-current drift (kn): breathes 0..~0.8 kn and periodically
+    dips to ~0 (slack water) so a calm-current state is exercised."""
+    p = utc_now.timestamp()
+    return max(0.0, 0.38 + 0.45 * math.sin(p / 480.0))
+
