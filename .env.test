# Test environment for the current lab setup:
#   - SignalK runs in Docker on compulab@192.168.2.11
#   - ESP32 device is reachable over OTA (WiFi) + BLE only (no USB)
#
# Source this before running pytest or the demo scripts:
#   set -a; source .env.test; set +a
# (the `set -a` makes the vars exported automatically)

# --- Remote SignalK host -----------------------------------------------
# Used by signalk/scripts/run-remote.sh + stop-remote.sh.
export REMOTE_HOST="compulab@192.168.2.11"
export REMOTE_DIR="/home/compulab/espdisp-signalk"
# Lab convention: the SK container on compulab is named `signalk`.
# run-remote.sh `docker rm -f`'s this name before recreating it, so
# anything previously running under that name will be replaced.
export SIGNALK_CONTAINER="signalk"

# Where the SK endpoints are reachable from this laptop (and from the
# device).  Same IP as the remote since Docker binds to the host.
export SK_HOST="192.168.2.11"
export SK_PORT="3000"

# --- Pytest / system test surface --------------------------------------
# Tests in tests/system/unattended/ read these.
export ESPDISP_SK_HOST="${SK_HOST}"
export ESPDISP_SK_PORT="${SK_PORT}"

# Device discovery: the device lives on the `esp-lab` AP run by
# compulab (10.42.0.0/24).  mDNS does not cross the routed segment,
# so pin the IP that dnsmasq leases out — currently 10.42.0.67 for
# the lab device.  Update this when a new device joins or the lease
# changes (check `sudo cat /var/lib/misc/dnsmasq.leases` on compulab).
export ESPDISP_HOST="${ESPDISP_HOST:-10.42.0.67}"

# Injection (tap/swipe/gesture) goes over BLE NUS — no USB on this rig.
# Do NOT set ESPDISP_SERIAL_PORT; that would prefer USB and fail.
export ESPDISP_BLE_NAME="${ESPDISP_BLE_NAME:-espdisp}"

# Web auth (if device basic-auth is enabled).  Leave unset for open
# devices.
# export ESPDISP_WEB_USERNAME="admin"
# export ESPDISP_WEB_PASSWORD="admin"

# SignalK login (demo container ships with admin/admin; change if you
# rotated the user via the SK admin UI).
export SIGNALK_USERNAME="${SIGNALK_USERNAME:-admin}"
export SIGNALK_PASSWORD="${SIGNALK_PASSWORD:-admin}"

# --- Firmware OTA target -----------------------------------------------
# Used by `make ota`.  Device lives on the routed esp-lab segment; pin
# to its DHCP lease (mDNS doesn't cross subnets).
export DEVICE_IP="${DEVICE_IP:-10.42.0.67}"

# --- Local-only secrets ------------------------------------------------
# Source `.env.test.local` if it exists.  That file is gitignored and
# holds creds we don't want in the repo (esp-lab WPA2-PSK, SignalK
# admin password if you've rotated it, etc.).  See
# `.env.test.local.example` for the template.
if [ -f "$(dirname "${BASH_SOURCE[0]:-$0}")/.env.test.local" ]; then
    . "$(dirname "${BASH_SOURCE[0]:-$0}")/.env.test.local"
fi
